{
  "name": "expo-paystack",
  "version": "0.1.0",
  "description": "The easiest way to integrate Paystack payments into your Expo app. Supports card, bank transfer, USSD, mobile money, and more. Built for Expo and the New Architecture.",
  "source": "./src/index.ts",
  "main": "./lib/commonjs/index.js",
  "module": "./lib/module/index.js",
  "types": "./lib/typescript/commonjs/index.d.ts",
  "react-native": "./src/index.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "import": {
        "types": "./lib/typescript/module/index.d.ts",
        "default": "./lib/module/index.js"
      },
      "require": {
        "types": "./lib/typescript/commonjs/index.d.ts",
        "default": "./lib/commonjs/index.js"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "src",
    "lib",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "bob build",
    "clean": "rimraf lib",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "prepare": "bob build"
  },
  "keywords": [
    "expo",
    "paystack",
    "react-native",
    "payments",
    "africa",
    "nigeria",
    "ghana",
    "kenya",
    "south-africa",
    "fintech",
    "mobile-payments",
    "card-payments",
    "bank-transfer"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/codinnovate/expo-paystack.git"
  },
  "homepage": "https://github.com/codinnovate/expo-paystack#readme",
  "bugs": {
    "url": "https://github.com/codinnovate/expo-paystack/issues"
  },
  "author": "Sam Adeyemi <adeyemis710@gmail.com>",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "peerDependencies": {
    "expo": ">=54.0.0",
    "react": ">=19.0.0",
    "react-native": ">=0.81.0",
    "react-native-webview": ">=13.0.0"
  },
  "dependencies": {
    "expo-crypto": ">=14.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@types/react": "~19.1.0",
    "eslint": "^9.18.0",
    "globals": "^15.14.0",
    "expo": "^54.0.0",
    "expo-crypto": "~15.0.9",
    "prettier": "^3.4.0",
    "react": "19.1.0",
    "react-native": "0.81.4",
    "react-native-builder-bob": "^0.43.0",
    "react-native-safe-area-context": "^5.6.0",
    "react-native-webview": "^13.13.0",
    "rimraf": "^6.0.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.20.0"
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      [
        "commonjs",
        {
          "esm": true
        }
      ],
      [
        "module",
        {
          "esm": true
        }
      ],
      "typescript"
    ]
  }
}
